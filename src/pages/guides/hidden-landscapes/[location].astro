---
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import ThresholdChip from '../../../components/ThresholdChip.astro';

const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const allLocations = await getCollection('locations', ({ data }) => data.guide === 'hidden-landscapes');
  // Curated sequence: prev/next follow the order field, displayed by name
  const sorted = allLocations.sort((a, b) => a.data.order - b.data.order);

  return sorted.map((loc, index) => {
    const prev = index > 0 ? sorted[index - 1] : null;
    const next = index < sorted.length - 1 ? sorted[index + 1] : null;

    return {
      params: { location: loc.data.slug },
      props: { entry: loc, prev, next },
    };
  });
}

type SymbolName = 'stair-descent' | 'trail-entrance' | 'bridge' | 'underpass' | 'park-edge' | 'path-ending' | 'slope-overlook';

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);

// Build Google Maps URL from coordinates
const mapsUrl = `https://www.google.com/maps?q=${entry.data.lat},${entry.data.lng}`;

// Vignette illustration slot: renders nothing until an asset exists for this slug.
// When adding: import and use Astro's Image component with
// src/assets/guides/hidden-landscapes/vignettes/{entry.data.slug}.jpg
---

<Base
  title={entry.data.title}
  description={entry.data.preview}
>
  <div class="page-wrapper">
    <div class="location-layout">

      <article class="location-article" aria-labelledby="location-title">

        <!-- Breadcrumb -->
        <nav class="location-breadcrumb" aria-label="Breadcrumb" data-reveal>
          <ol class="breadcrumb-list">
            <li class="breadcrumb-item">
              <a href={`${base}/`} class="breadcrumb-link">Toronto Micro-Atlas</a>
            </li>
            <li class="breadcrumb-item breadcrumb-sep" aria-hidden="true">/</li>
            <li class="breadcrumb-item">
              <a href={`${base}/guides/hidden-landscapes/`} class="breadcrumb-link" data-astro-reload>Hidden Landscapes</a>
            </li>
          </ol>
        </nav>

        <!-- H1 + meta header block -->
        <header class="location-header" data-reveal>
          <h1 class="location-title" id="location-title">{entry.data.title}</h1>
          <div class="location-meta">
            <ThresholdChip
              symbol={entry.data.thresholdType as SymbolName}
              label={entry.data.thresholdLabel}
            />
            <span class="location-neighbourhood">{entry.data.neighbourhood}</span>
          </div>
        </header>

        <!-- Contextual map plate -->
        <figure class="location-map-plate" data-reveal style="--reveal-delay: 40ms">
          <img
            src={`${base}/maps/context-${entry.data.slug}.svg`}
            alt={`Map of the streets and hidden landscape around ${entry.data.title}, threshold point marked at the centre`}
            width="800"
            height="600"
            loading="eager"
            decoding="async"
            class="location-map-image"
          />
          <figcaption class="location-map-caption">Street-to-landscape relationship at a glance.</figcaption>
        </figure>

        <!-- Illustration slot: renders only when vignette asset exists -->
        <!--
          Illustration slot: when a vignette image exists at
          src/assets/guides/hidden-landscapes/vignettes/{slug}.jpg,
          import and render it here with Astro's Image component.
          Currently empty; slot is preserved for future illustration plates.
        -->

        <!-- Observation prose -->
        <div class="location-observation prose" data-reveal style="--reveal-delay: 80ms">
          <Content />
        </div>

        <!-- Open in Maps -->
        <a
          href={mapsUrl}
          class="location-maps-link"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Open ${entry.data.title} in Google Maps`}
          data-reveal
          style="--reveal-delay: 80ms"
        >
          Open in Maps
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="maps-arrow">
            <line x1="3" y1="13" x2="13" y2="3"/>
            <polyline points="6,3 13,3 13,10"/>
          </svg>
        </a>

        <!-- Sources -->
        {entry.data.sources.length > 0 && (
          <aside class="location-sources" aria-label="Sources" data-reveal>
            <span class="location-sources-kicker">Sources</span>
            <ul class="location-sources-list">
              {entry.data.sources.map((source) => (
                <li>
                  <a
                    href={source.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="location-source-link"
                  >
                    {source.label}
                  </a>
                </li>
              ))}
            </ul>
          </aside>
        )}

      </article>

      <!-- Prev / Next navigation -->
      <nav class="location-nav" aria-label="Location navigation" data-reveal>
        <div class="location-nav-grid">
          {prev ? (
            <a
              href={`${base}/guides/hidden-landscapes/${prev.data.slug}/`}
              class="location-nav-card hover-raise"
              rel="prev"
            >
              <span class="location-nav-kicker">Previous</span>
              <span class="location-nav-name">{prev.data.title}</span>
            </a>
          ) : (
            <div class="location-nav-empty" aria-hidden="true"></div>
          )}
          {next ? (
            <a
              href={`${base}/guides/hidden-landscapes/${next.data.slug}/`}
              class="location-nav-card location-nav-card--next hover-raise"
              rel="next"
            >
              <span class="location-nav-kicker">Next</span>
              <span class="location-nav-name">{next.data.title}</span>
            </a>
          ) : (
            <div class="location-nav-empty" aria-hidden="true"></div>
          )}
        </div>
        <div class="location-nav-index-row">
          <a
            href={`${base}/guides/hidden-landscapes/`}
            class="location-nav-index-link"
            data-astro-reload
          >
            All locations
          </a>
        </div>
      </nav>

    </div>
  </div>
</Base>

<style>
  /* ============================================================
     Page layout: centered column within page-wrapper
     ============================================================ */

  .location-layout {
    max-width: var(--container);
    margin: 0 auto;
  }

  /* Article column: centered at --measure, with wider map plate */
  .location-article {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* All article children default to --measure width, centered */
  .location-article > * {
    width: 100%;
    max-width: var(--measure);
  }

  /* Map plate may extend wider */
  .location-map-plate {
    max-width: 840px;
  }

  /* Nav gets full container width */
  .location-nav {
    width: 100%;
    max-width: var(--container);
  }

  /* ============================================================
     Breadcrumb
     ============================================================ */

  .location-breadcrumb {
    margin-bottom: var(--space-8);
  }

  .breadcrumb-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
  }

  .breadcrumb-link {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    color: var(--ink-3);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: color var(--dur-1) var(--ease-out);
  }

  .breadcrumb-link:hover {
    color: var(--threshold);
  }

  .breadcrumb-link:focus-visible {
    outline: var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
  }

  .breadcrumb-sep {
    font-size: var(--text-xs);
    color: var(--street-major);
    user-select: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .breadcrumb-link {
      transition: none;
    }
  }

  /* ============================================================
     Header block: H1 + meta row
     ============================================================ */

  .location-header {
    margin-bottom: var(--space-8);
  }

  .location-title {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: clamp(var(--text-3xl), 5vw, var(--text-4xl));
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin-bottom: var(--space-3);
  }

  .location-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-3);
  }

  .location-neighbourhood {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    color: var(--ink-3);
    letter-spacing: 0.06em;
  }

  /* ============================================================
     Contextual map plate
     ============================================================ */

  .location-map-plate {
    background-color: var(--card);
    border: 1px solid var(--ink);
    padding: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .location-map-image {
    display: block;
    width: 100%;
    height: auto;
  }

  .location-map-caption {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    color: var(--ink-3);
    letter-spacing: 0.04em;
    padding-top: var(--space-3);
  }

  /* ============================================================
     Observation prose
     ============================================================ */

  .location-observation {
    margin-bottom: var(--space-8);
  }

  /* Override global .prose p to match editorial spec */
  .location-observation :global(p) {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: 1.75;
    color: var(--ink);
    margin-bottom: var(--space-6);
  }

  .location-observation :global(p:last-child) {
    margin-bottom: 0;
  }

  /* Context section heading: small-caps Archivo kicker above paragraphs */
  .location-observation :global(h2) {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-xs);
    font-variant: small-caps;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
  }

  .location-observation :global(em) {
    font-style: italic;
    color: var(--ink-2);
  }

  /* ============================================================
     Open in Maps link
     ============================================================ */

  .location-maps-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--ink);
    text-decoration: none;
    margin-bottom: var(--space-12);
    transition: color var(--dur-1) var(--ease-out);
  }

  .location-maps-link:hover {
    color: var(--threshold);
  }

  .location-maps-link:focus-visible {
    outline: var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
  }

  .maps-arrow {
    flex-shrink: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .location-maps-link {
      transition: none;
    }
  }

  /* ============================================================
     Sources aside
     ============================================================ */

  .location-sources {
    margin-bottom: var(--space-12);
    padding-top: var(--space-12);
    border-top: 1px solid var(--street-minor);
  }

  .location-sources-kicker {
    display: block;
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: var(--space-4);
  }

  .location-sources-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .location-source-link {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    color: var(--ink-3);
    text-decoration: none;
    text-underline-offset: 3px;
    transition: color var(--dur-1) var(--ease-out);
  }

  .location-source-link:hover {
    color: var(--ink);
    text-decoration: underline;
  }

  .location-source-link:focus-visible {
    outline: var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
  }

  @media (prefers-reduced-motion: reduce) {
    .location-source-link {
      transition: none;
    }
  }

  /* ============================================================
     Prev / Next navigation
     ============================================================ */

  .location-nav {
    padding-top: var(--space-12);
    border-top: 1px solid var(--street-minor);
    margin-top: var(--space-4);
  }

  .location-nav-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .location-nav-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-6);
    border: 1px solid var(--street-minor);
    text-decoration: none;
    color: var(--ink);
    transition:
      border-color var(--dur-2) var(--ease-out),
      transform var(--dur-2) var(--ease-out),
      box-shadow var(--dur-2) var(--ease-out);
  }

  .location-nav-card--next {
    text-align: right;
  }

  .location-nav-card:hover {
    border-color: var(--ink);
  }

  .location-nav-card:focus-visible {
    outline: var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
  }

  @media (prefers-reduced-motion: reduce) {
    .location-nav-card {
      transition: none;
    }
  }

  .location-nav-kicker {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
  }

  .location-nav-name {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--ink);
    line-height: 1.3;
  }

  .location-nav-empty {
    /* Empty cell preserves 2-col grid alignment */
  }

  .location-nav-index-row {
    display: flex;
    justify-content: center;
  }

  .location-nav-index-link {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--ink-3);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color var(--dur-1) var(--ease-out);
  }

  .location-nav-index-link:hover {
    color: var(--threshold);
  }

  .location-nav-index-link:focus-visible {
    outline: var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
  }

  @media (prefers-reduced-motion: reduce) {
    .location-nav-index-link {
      transition: none;
    }
  }

  /* ============================================================
     Responsive
     ============================================================ */

  @media (max-width: 767px) {
    .location-nav-grid {
      grid-template-columns: 1fr;
    }

    .location-nav-card--next {
      text-align: left;
    }
  }
</style>
