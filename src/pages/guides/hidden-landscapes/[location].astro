---
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import ThresholdChip from '../../../components/ThresholdChip.astro';

const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const allLocations = await getCollection('locations', ({ data }) => data.guide === 'hidden-landscapes');
  // Sort by name (alphabetical) for prev/next as spec requires
  const sorted = allLocations.sort((a, b) => a.data.order - b.data.order);

  return sorted.map((loc, index) => {
    const prev = index > 0 ? sorted[index - 1] : null;
    const next = index < sorted.length - 1 ? sorted[index + 1] : null;

    return {
      params: { location: loc.data.slug },
      props: { entry: loc, prev, next },
    };
  });
}

type SymbolName = 'stair-descent' | 'trail-entrance' | 'bridge' | 'underpass' | 'park-edge' | 'path-ending' | 'slope-overlook';

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);

// Build Google Maps URL from coordinates
const mapsUrl = `https://www.google.com/maps?q=${entry.data.lat},${entry.data.lng}`;

// Vignette illustration slot: renders nothing until an asset exists for this slug.
// When adding: import and use Astro's Image component with
// src/assets/guides/hidden-landscapes/vignettes/{entry.data.slug}.jpg
---

<Base
  title={entry.data.title}
  description={entry.data.preview}
>
  <div class="page-wrapper">
    <article class="location-article" aria-labelledby="location-title">

      <!-- Breadcrumb -->
      <nav class="location-breadcrumb" aria-label="Breadcrumb">
        <ol class="breadcrumb-list">
          <li class="breadcrumb-item">
            <a href={`${base}/`} class="breadcrumb-link">Toronto Micro-Atlas</a>
          </li>
          <li class="breadcrumb-item breadcrumb-sep" aria-hidden="true">/</li>
          <li class="breadcrumb-item">
            <a href={`${base}/guides/hidden-landscapes/`} class="breadcrumb-link">Hidden Landscapes</a>
          </li>
        </ol>
      </nav>

      <!-- H1 -->
      <h1 class="location-title" id="location-title">{entry.data.title}</h1>

      <!-- Threshold chip -->
      <div class="location-chip-row">
        <ThresholdChip
          symbol={entry.data.thresholdType as SymbolName}
          label={entry.data.thresholdLabel}
        />
        <span class="location-neighbourhood">{entry.data.neighbourhood}</span>
      </div>

      <!-- Contextual map slot (static placeholder for build-time SVG, populated later) -->
      <div
        class="location-map-slot"
        aria-label={`Map showing ${entry.data.title} and surrounding area`}
        role="img"
      >
        <!-- build-contextual-maps.mjs will place a static SVG here at build time -->
        <div class="location-map-placeholder" aria-hidden="true">
          <span class="location-map-placeholder-label">Contextual map</span>
          <span class="location-map-placeholder-coords">{entry.data.lat.toFixed(4)}, {entry.data.lng.toFixed(4)}</span>
        </div>
      </div>
      <p class="location-map-caption">Street-to-landscape relationship at a glance.</p>

      <!-- Illustration slot: renders only when vignette asset exists -->
      <!--
        Illustration slot: when a vignette image exists at
        src/assets/guides/hidden-landscapes/vignettes/{slug}.jpg,
        import and render it here with Astro's Image component.
        Currently empty; slot is preserved for future illustration plates.
      -->

      <!-- Observation prose -->
      <div class="location-observation">
        <Content />
      </div>

      <!-- Open in Maps -->
      <a
        href={mapsUrl}
        class="location-maps-link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Open ${entry.data.title} in Google Maps`}
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
          <polyline points="15 3 21 3 21 9"/>
          <line x1="10" y1="14" x2="21" y2="3"/>
        </svg>
        Open in Maps
      </a>

      <!-- Sources -->
      {entry.data.sources.length > 0 && (
        <aside class="location-sources" aria-label="Sources">
          <h2 class="location-sources-heading">Sources</h2>
          <ul class="location-sources-list">
            {entry.data.sources.map((source) => (
              <li class="location-source-item">
                <a
                  href={source.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="location-source-link"
                >
                  {source.label}
                </a>
              </li>
            ))}
          </ul>
        </aside>
      )}

    </article>

    <!-- Prev / Next navigation (by name, not number) -->
    <nav class="location-nav" aria-label="Location navigation">
      {prev && (
        <a
          href={`${base}/guides/hidden-landscapes/${prev.data.slug}/`}
          class="location-nav-link location-nav-link--prev"
          rel="prev"
        >
          <span class="location-nav-direction" aria-hidden="true">Previous</span>
          <span class="location-nav-name">{prev.data.title}</span>
        </a>
      )}
      <a
        href={`${base}/guides/hidden-landscapes/`}
        class="location-nav-link location-nav-link--index"
      >
        All locations
      </a>
      {next && (
        <a
          href={`${base}/guides/hidden-landscapes/${next.data.slug}/`}
          class="location-nav-link location-nav-link--next"
          rel="next"
        >
          <span class="location-nav-direction" aria-hidden="true">Next</span>
          <span class="location-nav-name">{next.data.title}</span>
        </a>
      )}
    </nav>

  </div>
</Base>

<style>
  /* ============================================================
     Breadcrumb
     ============================================================ */

  .location-breadcrumb {
    margin-bottom: var(--space-8);
  }

  .breadcrumb-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
  }

  .breadcrumb-link {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    color: var(--ink-3);
    text-decoration: none;
    letter-spacing: 0.04em;
  }

  .breadcrumb-link:hover {
    color: var(--threshold);
  }

  .breadcrumb-link:focus-visible {
    outline: var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
  }

  .breadcrumb-sep {
    font-size: var(--text-xs);
    color: var(--street-major);
    user-select: none;
  }

  /* ============================================================
     Location title and chip row
     ============================================================ */

  .location-title {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: clamp(var(--text-3xl), 5vw, var(--text-4xl));
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin-bottom: var(--space-4);
  }

  .location-chip-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3) var(--space-6);
    margin-bottom: var(--space-8);
  }

  .location-neighbourhood {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    color: var(--ink-3);
    letter-spacing: 0.06em;
  }

  /* ============================================================
     Contextual map slot
     ============================================================ */

  .location-map-slot {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: var(--paper);
    border: 1px solid var(--street-minor);
    position: relative;
    overflow: hidden;
    margin-bottom: var(--space-2);
  }

  .location-map-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
  }

  .location-map-placeholder-label {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--street-major);
  }

  .location-map-placeholder-coords {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    color: var(--street-minor);
    letter-spacing: 0.04em;
  }

  .location-map-caption {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    color: var(--ink-3);
    letter-spacing: 0.04em;
    margin-bottom: var(--space-10);
  }

  /* ============================================================
     Observation prose
     ============================================================ */

  .location-observation {
    max-width: var(--measure);
    margin-bottom: var(--space-10);
  }

  .location-observation :global(p) {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: 1.75;
    color: var(--ink);
    margin-bottom: var(--space-6);
  }

  .location-observation :global(p:last-child) {
    margin-bottom: 0;
  }

  .location-observation :global(h2) {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-base);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
  }

  .location-observation :global(em) {
    font-style: italic;
    color: var(--ink-2);
  }

  /* ============================================================
     Open in Maps link
     ============================================================ */

  .location-maps-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    color: var(--ink-2);
    text-decoration: none;
    border-bottom: 1px solid var(--street-minor);
    padding-bottom: var(--space-1);
    margin-bottom: var(--space-12);
    transition: color 0.1s ease, border-color 0.1s ease;
  }

  .location-maps-link:hover {
    color: var(--threshold);
    border-color: var(--threshold);
  }

  .location-maps-link:focus-visible {
    outline: var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
  }

  @media (prefers-reduced-motion: reduce) {
    .location-maps-link {
      transition: none;
    }
  }

  /* ============================================================
     Sources
     ============================================================ */

  .location-sources {
    margin-bottom: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--street-minor);
    max-width: var(--measure);
  }

  .location-sources-heading {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: var(--space-4);
  }

  .location-sources-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .location-source-link {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    color: var(--ink-3);
    text-decoration: none;
    text-underline-offset: 3px;
  }

  .location-source-link:hover {
    color: var(--ink);
    text-decoration: underline;
  }

  .location-source-link:focus-visible {
    outline: var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
  }

  /* ============================================================
     Prev / Next nav
     ============================================================ */

  .location-nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4) var(--space-6);
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-8);
    border-top: 1px solid var(--street-minor);
    margin-top: var(--space-4);
  }

  .location-nav-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    text-decoration: none;
    color: var(--ink);
    max-width: 20ch;
  }

  .location-nav-link--index {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    color: var(--ink-3);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    max-width: none;
  }

  .location-nav-link:hover .location-nav-name {
    color: var(--threshold);
  }

  .location-nav-link--index:hover {
    color: var(--threshold);
  }

  .location-nav-link:focus-visible {
    outline: var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
  }

  .location-nav-direction {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-3);
  }

  .location-nav-name {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--ink);
    line-height: 1.3;
    transition: color 0.1s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .location-nav-name {
      transition: none;
    }
  }

  /* ============================================================
     Responsive
     ============================================================ */

  @media (min-width: 768px) {
    .location-map-slot {
      max-width: 600px;
    }
  }
</style>
