---
import Base from '../layouts/Base.astro';

const base = import.meta.env.BASE_URL;
---

<Base title="Home">
  <h1>Toronto Micro-Atlas</h1>
  <p>An independent web publication of Field Guides about noticing Toronto.</p>

  <section>
    <h2>Field Guides</h2>
    <ul>
      <li>
        <a href={`${base}/guides/hidden-landscapes/`}>Field Guide 01: Hidden Landscapes</a>
        <p>Eight threshold locations where Toronto's surface cracks open into something older.</p>
      </li>
    </ul>
  </section>
</Base>
