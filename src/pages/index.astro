---
import Base from '../layouts/Base.astro';
import ThresholdSymbol from '../components/ThresholdSymbol.astro';

const base = import.meta.env.BASE_URL.replace(/\/+$/, "");
---

<Base
  title={undefined}
  description="An independent web publication of Field Guides about noticing and using Toronto."
>
  <div class="home-wrapper">

    <!-- Publication lede -->
    <section class="home-lede" aria-labelledby="lede-kicker">
      <div class="home-lede-inner">
        <p class="lede-kicker" id="lede-kicker" aria-label="Toronto Micro-Atlas">Toronto&nbsp;Micro-Atlas</p>
        <hr class="lede-rule" aria-hidden="true" />
        <p class="lede-text" data-reveal>Toronto Micro-Atlas is an independent web publication of Field Guides about noticing and using Toronto. Each guide takes one specific way the city works, where it hides things, what it shows someone paying attention, and builds it into an interactive map with careful editorial research.</p>
      </div>
    </section>

    <!-- Field Guide 02 feature block (newest first) -->
    <section class="feature-block feature-block--fg2" id="field-guides" aria-labelledby="feature-title-fg2">
      <div class="feature-inner">

        <!-- Left column: text -->
        <div class="feature-text">
          <span class="feature-kicker feature-kicker--fg2" data-reveal style="--reveal-delay: 0ms">Field Guide · New</span>
          <h1 class="feature-title" id="feature-title-fg2" data-reveal style="--reveal-delay: 40ms">Sidewalk Forest</h1>
          <p class="feature-blurb" data-reveal style="--reveal-delay: 80ms">Toronto keeps a ledger of every street tree it tends: 688,335 of them, each with a species, a trunk measurement, and an address. Sidewalk Forest draws the whole ledger at once, one glowing dot per tree, then hands you the map. Tap any dot and the city tells you the name of the tree outside your door.</p>
          <a
            href={`${base}/guides/sidewalk-forest/`}
            class="feature-cta feature-cta--fg2 hover-raise"
            data-astro-reload
            data-reveal
            style="--reveal-delay: 120ms"
          >Open the Field Guide</a>
        </div>

        <!-- Right column: the galaxy render as a specimen plate -->
        <div class="feature-plate" aria-hidden="true" data-reveal style="--reveal-delay: 160ms">
          <img src={`${base}/data/fg02/r/base-lo.webp`} alt="" loading="lazy" decoding="async" width="2048" height="1580" />
          <span class="feature-plate-caption">688,335 trees · one dot each</span>
        </div>

      </div>
    </section>

    <!-- Field Guide 01 feature block -->
    <section class="feature-block" aria-labelledby="feature-title">
      <div class="feature-inner">

        <!-- Left column: text -->
        <div class="feature-text">
          <span class="feature-kicker" data-reveal style="--reveal-delay: 0ms">Field Guide</span>
          <h2 class="feature-title" id="feature-title" data-reveal style="--reveal-delay: 40ms">Hidden Landscapes</h2>
          <p class="feature-blurb" data-reveal style="--reveal-delay: 80ms">Hidden Landscapes documents eight threshold moments where Toronto's orderly street grid suddenly gives way to valleys, ravines, escarpments, and watercourses. Each entry is a specific place, a specific crossing, and a specific reason to look twice at what the city is built on top of.</p>
          <a
            href={`${base}/guides/hidden-landscapes/`}
            class="feature-cta hover-raise"
            data-astro-reload
            data-reveal
            style="--reveal-delay: 120ms"
          >Open the Field Guide</a>
        </div>

        <!-- Right column: threshold glyph specimen sheet -->
        <div class="feature-glyphs" aria-hidden="true" data-reveal style="--reveal-delay: 160ms">
          <ThresholdSymbol name="stair-descent"    size={64}  class="glyph glyph--lg"  aria-hidden="true" />
          <ThresholdSymbol name="slope-overlook"   size={48}  class="glyph glyph--md"  aria-hidden="true" />
          <ThresholdSymbol name="bridge"            size={56}  class="glyph glyph--ml"  aria-hidden="true" />
          <ThresholdSymbol name="trail-entrance"   size={40}  class="glyph glyph--sm"  aria-hidden="true" />
          <ThresholdSymbol name="underpass"         size={52}  class="glyph glyph--ml"  aria-hidden="true" />
          <ThresholdSymbol name="park-edge"         size={44}  class="glyph glyph--sm"  aria-hidden="true" />
          <ThresholdSymbol name="path-ending"       size={36}  class="glyph glyph--xs"  aria-hidden="true" />
        </div>

      </div>
    </section>

    <!-- Under observation -->
    <section class="under-observation" aria-labelledby="observation-heading">
      <div class="under-observation-inner">
        <h2 class="section-label" id="observation-heading">Under observation</h2>
        <dl class="observation-list">

          <div class="observation-row" data-reveal style="--reveal-delay: 0ms">
            <dt class="observation-term">Farmers Markets</dt>
            <dd class="observation-desc">A rotating atlas of Toronto's outdoor markets, mapped by neighbourhood and season.</dd>
          </div>

          <div class="observation-row" data-reveal style="--reveal-delay: 40ms">
            <dt class="observation-term">Quiet Third Places</dt>
            <dd class="observation-desc">The libraries, reading rooms, lobbies, and garden corners where the city allows you to sit still.</dd>
          </div>

          <div class="observation-row" data-reveal style="--reveal-delay: 80ms">
            <dt class="observation-term">Shade and Cooling</dt>
            <dd class="observation-desc">Where to find cover on a hot day: a taxonomy of trees, awnings, tunnels, and water in the urban surface.</dd>
          </div>

        </dl>
      </div>
    </section>

  </div>
</Base>

<style>
  /* ============================================================
     Home wrapper
     ============================================================ */

  .home-wrapper {
    display: flex;
    flex-direction: column;
  }

  /* ============================================================
     Publication lede
     ============================================================ */

  .home-lede {
    padding-block: var(--space-16) var(--space-12);
    padding-inline: var(--gutter);
    border-bottom: 1px solid var(--street-minor);
  }

  @media (max-width: 767px) {
    .home-lede {
      padding-block: var(--space-12) var(--space-8);
    }
  }

  .home-lede-inner {
    max-width: var(--container);
    margin-inline: auto;
  }

  .lede-kicker {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: var(--space-4);
  }

  .lede-rule {
    border: none;
    border-top: 1px solid var(--street-minor);
    margin-bottom: var(--space-8);
    max-width: var(--measure-lede);
  }

  .lede-text {
    font-family: var(--font-body);
    font-size: var(--text-xl);
    line-height: 1.65;
    color: var(--ink-2);
    max-width: var(--measure-lede);
  }

  /* ============================================================
     Feature block
     ============================================================ */

  .feature-block {
    background-color: var(--landscape);
    padding-block: var(--space-16);
    padding-inline: var(--gutter);
  }

  /* FG02 carries its own nocturne palette into the shell */
  .feature-block--fg2 {
    background-color: hsl(211, 42%, 9%);
  }

  /* Doubled class beats the base .feature-kicker/.feature-cta rules that
     appear later in this style block. */
  .feature-kicker.feature-kicker--fg2 {
    color: hsl(48, 90%, 64%);
  }

  .feature-cta.feature-cta--fg2 {
    background-color: transparent;
    color: hsl(48, 90%, 64%);
    border: 1px solid hsl(48, 90%, 64%);
  }

  @media (hover: hover) {
    .feature-cta.feature-cta--fg2:hover {
      background-color: hsl(48, 90%, 64%);
      color: hsl(211, 42%, 9%);
      border-color: hsl(48, 90%, 64%);
    }
  }

  .feature-cta.feature-cta--fg2:focus-visible {
    outline: 2px solid hsl(48, 90%, 64%);
    outline-offset: 3px;
  }

  .feature-plate {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    border: 1px solid hsl(210, 26%, 24%);
    padding: var(--space-3);
    background-color: hsl(212, 45%, 7%);
  }

  .feature-plate img {
    width: 100%;
    height: auto;
    display: block;
  }

  .feature-plate-caption {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: hsl(214, 16%, 58%);
    text-align: right;
  }

  @media (min-width: 768px) {
    .feature-block {
      padding-block: var(--space-24);
    }
  }

  .feature-inner {
    max-width: var(--container);
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  @media (min-width: 1024px) {
    .feature-inner {
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
      gap: var(--space-16);
    }
  }

  /* Left column */
  .feature-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .feature-kicker {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    /* Solid paper on spruce: 8.8:1. Translucent kickers fail AA here
       (0.65 alpha blends to ~2.9:1); hierarchy comes from size and
       letterspacing instead of lightness. */
    color: var(--paper);
  }

  .feature-title {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: clamp(2.75rem, 8vw, 5rem);
    line-height: 1.02;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    /* #FAF6EC on #147D64 = 8.82:1 -- passes AAA */
    color: var(--paper);
    margin: 0;
  }

  .feature-blurb {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: 1.65;
    /* Solid paper on spruce: 8.8:1. The 0.88 alpha version blended to
       ~4.0:1 and failed AA for 18px regular text. */
    color: var(--paper);
    max-width: 55ch;
  }

  /* Paper CTA button */
  .feature-cta {
    display: inline-block;
    align-self: flex-start;
    background-color: var(--paper);
    color: var(--ink);
    font-family: var(--font-ui);
    font-size: var(--text-base);
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    padding: var(--space-3) var(--space-6);
    border: 1px solid var(--ink);
    /* Sharp corners -- 1px max per design system */
    border-radius: 1px;
    /* hover-raise handles transform/color transitions */
  }

  @media (hover: hover) {
    .feature-cta:hover {
      background-color: var(--threshold);
      color: var(--paper);
      border-color: var(--threshold);
    }
  }

  .feature-cta:active {
    transform: scale(0.98);
  }

  .feature-cta:focus-visible {
    outline: 2px solid var(--paper);
    outline-offset: 3px;
  }

  /* Right column: glyph specimen sheet */
  .feature-glyphs {
    display: grid;
    grid-template-columns: repeat(3, auto);
    grid-template-rows: repeat(3, auto);
    gap: var(--space-8) var(--space-6);
    justify-content: center;
    align-items: center;
    /* cream strokes at 30-45% opacity against --landscape */
    color: rgba(250, 246, 236, 0.38);
  }

  /* Staggered placement to evoke an engraved specimen sheet */
  .glyph--lg { grid-column: 1; grid-row: 1; }
  .glyph--md { grid-column: 3; grid-row: 1; }
  .glyph--ml { grid-column: 2; grid-row: 2; }
  .glyph--sm:nth-of-type(4) { grid-column: 1; grid-row: 3; }
  /* Reselect by DOM order for items sharing the same size class */
  .feature-glyphs .glyph:nth-child(4) { grid-column: 1; grid-row: 3; }
  .feature-glyphs .glyph:nth-child(5) { grid-column: 3; grid-row: 2; }
  .feature-glyphs .glyph:nth-child(6) { grid-column: 2; grid-row: 3; }
  .feature-glyphs .glyph:nth-child(7) { grid-column: 3; grid-row: 3; }

  /* On mobile, collapse to a single centered row of small motifs */
  @media (max-width: 1023px) {
    .feature-glyphs {
      display: flex;
      flex-direction: row;
      flex-wrap: wrap;
      gap: var(--space-6);
      justify-content: center;
      /* de-emphasize on mobile -- just a quiet motif bar */
      color: rgba(250, 246, 236, 0.28);
    }

    /* Show only 3 representative glyphs on mobile */
    .feature-glyphs .glyph:nth-child(n+4) {
      display: none;
    }
  }

  /* ============================================================
     Under observation
     ============================================================ */

  .under-observation {
    padding-block: var(--space-16);
    padding-inline: var(--gutter);
  }

  @media (min-width: 768px) {
    .under-observation {
      padding-block: var(--space-16) var(--space-24);
    }
  }

  .under-observation-inner {
    max-width: var(--container);
    margin-inline: auto;
  }

  .section-label {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: var(--space-6);
    /* Section heading sits above the hairline border of the first row */
  }

  /* Definition list as two-column rows */
  .observation-list {
    border-top: 1px solid var(--street-minor);
  }

  .observation-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2);
    padding-block: var(--space-6);
    border-bottom: 1px solid var(--street-minor);
  }

  @media (min-width: 768px) {
    .observation-row {
      grid-template-columns: 240px minmax(0, 1fr);
      gap: var(--space-8);
      align-items: baseline;
    }
  }

  .observation-term {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink);
    /* dt elements are block by default; no additional display needed */
  }

  .observation-desc {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: 1.6;
    color: var(--ink-2);
    /* natural measure from the grid; max-width keeps very wide viewports readable */
    max-width: 58ch;
    margin: 0;
  }

  /* ============================================================
     Reduced motion: all transitions already handled by motion.css
     and the [data-reveal] system. Active-press scale on CTA only.
     ============================================================ */

  @media (prefers-reduced-motion: reduce) {
    .feature-cta:active {
      transform: none;
    }
  }
</style>
